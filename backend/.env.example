MONGODB_URL=your_mongodb_connection_string
MONGODB_DB_NAME=careerverse
JWT_SECRET_KEY=change_this_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://careerverse-khaki.vercel.app

# Optional AI settings
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Optional email settings for OTP delivery.
# If these are not set, OTP codes are printed in the backend terminal.
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USERNAME=your_email_username
SMTP_PASSWORD=your_email_password
EMAIL_FROM=your_sender_email
